# =============================================================================
# Aminy Telehealth - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# -----------------------------------------------------------------------------
# Stripe Configuration (Payments)
# Get these from: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# Publishable key (safe for frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Price IDs (create in Stripe Dashboard > Products)
VITE_STRIPE_CONSULT_PRICE_ID=price_consult_25min
VITE_STRIPE_EXTENDED_PRICE_ID=price_extended_50min
VITE_STRIPE_FOLLOWUP_PRICE_ID=price_followup_15min

# Subscription price IDs
VITE_STRIPE_STARTER_MONTHLY=price_starter_monthly
VITE_STRIPE_STARTER_ANNUAL=price_starter_annual
VITE_STRIPE_CORE_MONTHLY=price_core_monthly
VITE_STRIPE_CORE_ANNUAL=price_core_annual
VITE_STRIPE_PRO_MONTHLY=price_pro_monthly
VITE_STRIPE_PRO_ANNUAL=price_pro_annual

# -----------------------------------------------------------------------------
# Daily.co Configuration (Video Calls)
# Get these from: https://dashboard.daily.co/developers
# -----------------------------------------------------------------------------
VITE_DAILY_DOMAIN=your-domain.daily.co

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
VITE_API_URL=https://your-project-id.supabase.co/functions/v1/make-server-8a022548

# Development mode (uses mock data instead of real API)
VITE_USE_MOCK_DATA=true

# =============================================================================
# SERVER-SIDE ONLY (for Supabase Edge Functions)
# These go in Supabase Dashboard > Settings > Edge Functions > Secrets
# DO NOT put these in .env.local!
# =============================================================================
# STRIPE_SECRET_KEY=sk_test_your-secret-key
# DAILY_API_KEY=your-daily-api-key
# TWILIO_ACCOUNT_SID=your-twilio-sid
# TWILIO_AUTH_TOKEN=your-twilio-token
# TWILIO_PHONE_NUMBER=+1234567890
# SENDGRID_API_KEY=your-sendgrid-key
# FROM_EMAIL=noreply@aminy.app

# =============================================================================
# PUSH NOTIFICATIONS (VAPID)
# =============================================================================
# Frontend (put in .env.local)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Backend (put in Supabase Edge Function Secrets)
# VAPID_PUBLIC_KEY=same-as-above
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:hello@aminy.app
