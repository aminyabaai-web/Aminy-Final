# =============================================================================
# AMINY ENVIRONMENT VARIABLES - COMPLETE PRODUCTION CHECKLIST
# =============================================================================
# Copy this file to .env.local and fill in the values for development
# For production, set these in your hosting platform (Vercel, Netlify, etc.)
# NEVER commit .env.local or .env to git!
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE - Required for all database operations
# -----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# API endpoint for Claude AI
VITE_API_URL=https://your-project.supabase.co/functions/v1/make-server-8a022548

# -----------------------------------------------------------------------------
# STRIPE - Required for payments
# -----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Subscription Price IDs (create in Stripe Dashboard > Products)
# Use pk_test_ keys for development, pk_live_ for production
VITE_PRICE_STARTER_MONTHLY=price_starter_monthly
VITE_PRICE_STARTER_ANNUAL=price_starter_annual
VITE_PRICE_CORE_MONTHLY=price_core_monthly
VITE_PRICE_CORE_ANNUAL=price_core_annual
VITE_PRICE_PRO_MONTHLY=price_pro_monthly
VITE_PRICE_PRO_ANNUAL=price_pro_annual
VITE_PRICE_PROPLUS_MONTHLY=price_proplus_monthly
VITE_PRICE_PROPLUS_ANNUAL=price_proplus_annual

# Telehealth Visit Price IDs
VITE_PRICE_INITIAL_CONSULT=price_initial_consult
VITE_PRICE_FOLLOWUP=price_followup
VITE_PRICE_EMERGENCY=price_emergency
VITE_PRICE_EXTENDED=price_extended

# Session Bundle Price IDs
VITE_PRICE_BUNDLE_CONSULT_4=price_bundle_consult_4
VITE_PRICE_BUNDLE_CONSULT_8=price_bundle_consult_8
VITE_PRICE_BUNDLE_DEEP_3=price_bundle_deep_3
VITE_PRICE_BUNDLE_DEEP_6=price_bundle_deep_6
VITE_PRICE_BUNDLE_MIXED=price_bundle_mixed

# Legacy Price IDs (for backward compatibility)
VITE_STRIPE_CONSULT_PRICE_ID=price_consult_25min
VITE_STRIPE_EXTENDED_PRICE_ID=price_extended_50min
VITE_STRIPE_FOLLOWUP_PRICE_ID=price_followup_15min
VITE_STRIPE_STARTER_MONTHLY=price_starter_monthly
VITE_STRIPE_STARTER_ANNUAL=price_starter_annual
VITE_STRIPE_CORE_MONTHLY=price_core_monthly
VITE_STRIPE_CORE_ANNUAL=price_core_annual
VITE_STRIPE_PRO_MONTHLY=price_pro_monthly
VITE_STRIPE_PRO_ANNUAL=price_pro_annual

# -----------------------------------------------------------------------------
# TELEHEALTH - Video calling (Daily.co)
# -----------------------------------------------------------------------------
# Get from: https://dashboard.daily.co/developers
VITE_DAILY_DOMAIN=your-domain.daily.co

# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS - Web Push (VAPID)
# -----------------------------------------------------------------------------
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BLEr1Jntq45v2...
# Private key goes in Supabase Secrets, not here

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS
# -----------------------------------------------------------------------------
# Sentry - Error tracking (https://sentry.io)
VITE_SENTRY_DSN=https://abc123@o123456.ingest.sentry.io/1234567

# Google Analytics 4 (https://analytics.google.com)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
VITE_APP_NAME=Aminy
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://aminy.app

# Set to false in production to use real data
VITE_USE_MOCK_DATA=true

# =============================================================================
# SUPABASE EDGE FUNCTION SECRETS
# =============================================================================
# These are NOT set here - they go in Supabase Dashboard > Settings > Secrets
#
# ANTHROPIC_API_KEY=sk-ant-...              # Claude API for AI chat
# STRIPE_SECRET_KEY=sk_live_...             # Stripe payments (backend)
# TWILIO_ACCOUNT_SID=AC...                  # SMS notifications
# TWILIO_AUTH_TOKEN=...                     # SMS notifications
# TWILIO_PHONE_NUMBER=+1...                 # SMS sender number
# VAPID_PUBLIC_KEY=...                      # Same as frontend
# VAPID_PRIVATE_KEY=...                     # Push notification signing
# VAPID_SUBJECT=mailto:hello@aminy.app      # Push notification contact
# DAILY_API_KEY=...                         # Telehealth room creation
# SENDGRID_API_KEY=SG...                    # Email sending
# FROM_EMAIL=noreply@aminy.app              # Email sender address

# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =============================================================================
# Before launching to production, ensure:
#
# 1. DATABASE
#    [ ] All migrations run: supabase db push
#    [ ] RLS policies enabled on all tables
#    [ ] Backup strategy configured
#    [ ] Read replicas for scale (optional)
#
# 2. PAYMENTS
#    [ ] Stripe webhook endpoint configured
#    [ ] All price IDs created in Stripe Dashboard
#    [ ] Use pk_live_ and sk_live_ keys
#    [ ] Tax calculation enabled if needed
#
# 3. AI
#    [ ] ANTHROPIC_API_KEY set in Supabase secrets
#    [ ] Edge function deployed: supabase functions deploy
#    [ ] Rate limiting configured
#
# 4. NOTIFICATIONS
#    [ ] VAPID keys generated and set
#    [ ] Twilio account verified for SMS
#    [ ] SendGrid domain verified for email
#
# 5. SECURITY
#    [ ] HIPAA BAA signed with Supabase
#    [ ] SSL/TLS configured
#    [ ] Content Security Policy headers
#    [ ] Audit logging enabled (IS_PRODUCTION=true)
#
# 6. MONITORING
#    [ ] Sentry DSN configured
#    [ ] Google Analytics verified
#    [ ] Error alerting set up
#
# =============================================================================
