# ============================================
# AMINY MVP - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================

# ============================================
# SUPABASE (Required)
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# ============================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (for Edge Functions only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# STRIPE PAYMENTS (Required for subscriptions)
# Get these from: https://dashboard.stripe.com/apikeys
# ============================================
# Publishable key (safe for frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key (Edge Functions only - keep secret!)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (create in Stripe Dashboard > Products)
VITE_STRIPE_STARTER_MONTHLY=price_starter_monthly
VITE_STRIPE_STARTER_ANNUAL=price_starter_annual
VITE_STRIPE_CORE_MONTHLY=price_core_monthly
VITE_STRIPE_CORE_ANNUAL=price_core_annual
VITE_STRIPE_PRO_MONTHLY=price_pro_monthly
VITE_STRIPE_PRO_ANNUAL=price_pro_annual

# ============================================
# AI PROVIDER (Required for AI chat - choose ONE)
# Supports both OpenAI and Anthropic (Claude)
# OpenAI is checked first, then Anthropic as fallback
# ============================================
# This is set in Supabase Edge Function secrets, not frontend

# OPTION 1: OpenAI (Recommended)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OPTION 2: Anthropic (Claude)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# DAILY.CO VIDEO (Required for telehealth)
# Get from: https://dashboard.daily.co/developers
# ============================================
# This is set in Supabase Edge Function secrets
DAILY_API_KEY=...

# Domain for video rooms
VITE_DAILY_DOMAIN=aminy

# ============================================
# ANALYTICS (Optional - for production)
# ============================================
# Google Analytics 4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel
VITE_MIXPANEL_TOKEN=your_mixpanel_token

# Amplitude
VITE_AMPLITUDE_API_KEY=your_amplitude_key

# ============================================
# ERROR TRACKING (Optional - for production)
# ============================================
# Sentry
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# LogRocket
VITE_LOGROCKET_APP_ID=your-app/your-project

# ============================================
# EMAIL (For email digests and notifications)
# ============================================
# SendGrid, Resend, or similar
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=hello@aminy.com

# ============================================
# FEATURE FLAGS (Optional overrides)
# ============================================
VITE_ENABLE_LIVE_VISION=false
VITE_ENABLE_FILE_ATTACHMENTS=false
VITE_ENABLE_MULTI_LANGUAGE=false

# ============================================
# DEVELOPMENT
# ============================================
VITE_APP_ENV=development
# Set to 'production' for production builds
