# --- SUPABASE (REQUIRED) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_API_URL=https://YOUR_PROJECT.supabase.co/functions/v1/make-server-8a022548

# --- STRIPE (REQUIRED for payments) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
# Price IDs from Stripe Dashboard > Products
VITE_STRIPE_PRICE_CORE_MONTHLY=price_xxx
VITE_STRIPE_PRICE_CORE_YEARLY=price_xxx
VITE_STRIPE_PRICE_PRO_MONTHLY=price_xxx
VITE_STRIPE_PRICE_PRO_YEARLY=price_xxx
VITE_STRIPE_PRICE_PROPLUS_MONTHLY=price_xxx
VITE_STRIPE_PRICE_PROPLUS_YEARLY=price_xxx

# --- DAILY.CO (REQUIRED for telehealth) ---
VITE_DAILY_API_KEY=YOUR_DAILY_KEY

# --- SENTRY (REQUIRED for error tracking) ---
VITE_SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT

# --- FEATURE FLAGS (set for production) ---
VITE_DEMO_MODE=false
VITE_DEV_MODE=false
VITE_ENABLE_RETENTION_EMAILS=true

