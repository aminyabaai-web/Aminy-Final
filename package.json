    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:e2e:accessibility": "playwright test accessibility.spec.ts",
    "test:e2e:visual": "playwright test visual-regression.spec.ts visual-audit.spec.ts",
    "test:e2e:design": "playwright test design-system.spec.ts",
    "test:e2e:journeys": "playwright test user-journeys.spec.ts",
    "test:e2e:components": "playwright test component-interactions.spec.ts",
    "test:e2e:ai": "playwright test ai-integrations.spec.ts",
    "test:e2e:api": "playwright test api-integrations.spec.ts",
    "test:e2e:audit": "playwright test design-audit-report.spec.ts",
    "test:e2e:full-audit": "playwright test design-audit-report.spec.ts --project=chromium && cat e2e-reports/DESIGN-AUDIT-REPORT.md",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report",
    "test:e2e:debug": "playwright test --debug",
